# Copy this file to .env and fill in your own values.
# Never commit the real .env file — it contains secrets.

# ── API keys ──────────────────────────────────────────────────────────────────
# Visual Crossing Weather API  →  https://www.visualcrossing.com/
VISUALCROSSING_API_KEY=your_visualcrossing_api_key_here

# IQAir / AirVisual API  →  https://www.iqair.com/air-pollution-data-api
AIRVISUAL_API_KEY=your_airvisual_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string — adjust user, host, port, and database name
DATABASE_URL=postgresql://<db_user>@localhost:5432/<db_name>

# ── ETL date range ────────────────────────────────────────────────────────────
DEFAULT_START_DATE=2024-06-03
DEFAULT_END_DATE=2024-09-03

# ── Cities ────────────────────────────────────────────────────────────────────
# Pipe-delimited pairs: display_name|api_location|display_name|api_location|...
# The api_location value is passed directly to the Visual Crossing API.
# Example (add as many cities as you like):
CITIES=Athens|Athens,Greece|London|London,UK|Paris|Paris,France
